# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

NEXT_PUBLIC_GOKEI_API_URL="https://staging.backend.getskip.ai/api/spot"
NEXT_PUBLIC_GOKEI_WIDGET_URL="https://staging.spot.getskip.ai"
NEXT_PUBLIC_GOKEI_PUBLIC_KEY="PK_EXAMPLE"

SKIP_PAY_API = "https://staging.pay.getskip.ai"

# CNPL (Care Now Pay Later) — SkipPay credentials are server-side secrets.
# Set SKIPPAY_API_URL and SKIPAY_CLIENT_SECRET in the Cloudflare Pages dashboard
# (Settings > Environment Variables) for production/preview deployments, and in
# .dev.vars for local development with `wrangler pages dev`.
