# .dev.vars.example — copy to .dev.vars for local wrangler pages dev
# This file is the Cloudflare equivalent of .env for Pages Functions.
# .dev.vars is read automatically by `wrangler pages dev` and is NOT committed to git.
#
# Usage:
#   cp .dev.vars.example .dev.vars
#   # fill in real values, then run:
#   pnpm dev          # terminal 1 — Next.js on :3000
#   pnpm dev:pages    # terminal 2 — Cloudflare Pages on :3001 (proxies :3000)
#   # open http://localhost:3001

SKIPPAY_API_URL="https://staging.pay.getskip.ai"
SKIPAY_CLIENT_SECRET="your-skippay-client-secret"
